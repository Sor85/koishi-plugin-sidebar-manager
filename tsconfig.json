{
  "compilerOptions": {
    "target": "es2022",
    "module": "esnext",
    "sourceMap": true,
    "declaration": true,
    "emitDeclarationOnly": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "moduleResolution": "bundler",
    "strictBindCallApply": true,
    "types": [
      "node"
    ],
    "rootDir": "src",
    "outDir": "lib"
  },
  "include": [
    "src"
  ]
}
